{
  "name": "@kdb-dashboard-library/finance-ui",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": ["dist", "src/theme.css"],
  "dependencies": {
    "@kdb-dashboard-library/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec tsup src/index.ts --tsconfig tsconfig.build.json --format esm --external react,react-dom,recharts,@kdb-dashboard-library/protocol && pnpm exec tsc --project tsconfig.dts.json",
    "lint": "pnpm exec tsc --project tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --passWithNoTests",
    "typecheck": "pnpm exec tsc --project tsconfig.json --noEmit"
  }
}
